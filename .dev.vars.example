# 仅用于 wrangler pages dev 本地预览 Cloudflare Pages Functions。
# 复制为 .dev.vars 后填入真实值，.dev.vars 已在 .gitignore 中。
# 这些变量在生产环境由 Cloudflare Dashboard 注入，不要提交。

OPENAI_API_KEY=sk-xxxx
# 中转站时填完整 base URL（必须带 /v1）；为空则走官方 https://api.openai.com/v1
# 示例：OPENAI_BASE_URL=https://api.chshapi.cn/v1
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TIMEOUT_MS=120000
