{
  "name": "promptcanvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "node --watch server/index.mjs",
    "backend": "node server/index.mjs",
    "start": "node server/index.mjs",
    "check:backend": "node --check server/index.mjs && node --test server/*.test.mjs",
    "test:backend": "node --test server/*.test.mjs",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "vite": "^6.0.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.2.0"
  }
}
