# ─── 前端（Vite）────────────────────────────────────────────────
# 同源部署（Cloudflare Pages / Express + Vite proxy）时留空即可，
# 前端会请求相对路径 /api/...。仅在前后端分别部署到不同域名时才设值。
VITE_API_BASE_URL=

# ─── 本地 Express 后端（npm run dev:backend）─────────────────────
# Cloudflare Pages 部署时这些变量改在 Dashboard 配置，本文件只服务于本地。
OPENAI_API_KEY=sk-xxxx
# 默认走官方 https://api.openai.com/v1，使用中转站时填中转站完整 base URL（必须带 /v1）
# 示例：OPENAI_BASE_URL=https://api.chshapi.cn/v1
OPENAI_BASE_URL=
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TIMEOUT_MS=120000
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=20
ACCESS_LOG=true
