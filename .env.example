# ─── 前端（Vite）────────────────────────────────────────────────
# 同源部署（Cloudflare Pages / Express + Vite proxy）时留空即可，
# 前端会请求相对路径 /api/...。仅在前后端分别部署到不同域名时才设值。
VITE_API_BASE_URL=

# ─── 本地 Express 后端（npm run dev:backend）─────────────────────
# 注意：自 v2 起，OpenAI 凭据（apiKey / baseUrl / model）改由访客在前端
# Settings 中配置，存于浏览器 localStorage，后端不再读 OPENAI_* 环境变量。
# 这里只保留运营性配置：端口、CORS、速率、日志。
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=20
ACCESS_LOG=true
